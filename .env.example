# Environment Variables Template
# Copy this to .env.local and fill in your actual values

# ============================================================================
# EXCHANGE RATE API
# ============================================================================
# No API key required - free tier works fine
# Leave empty to use fallback (Frankfurter)
# NEXT_PUBLIC_EXCHANGE_RATE_PROVIDER=exchangerate-api

# ============================================================================
# CHANNEL MANAGER INTEGRATION (Optional)
# ============================================================================
# Choose one: lodgify or hostaway

# For Lodgify
# Sign up: https://lodgify.com
# Get API key from: Properties > Settings > API
NEXT_PUBLIC_CHANNEL_PROVIDER=lodgify
NEXT_PUBLIC_CHANNEL_API_URL=https://api.lodgify.com/v1
NEXT_PUBLIC_CHANNEL_API_KEY=your_lodgify_api_key_here

# For Hostaway (alternative to Lodgify)
# Sign up: https://www.hostaway.com
# Get API key from: Settings > API
# NEXT_PUBLIC_CHANNEL_PROVIDER=hostaway
# NEXT_PUBLIC_CHANNEL_API_URL=https://api.hostaway.com/v3
# NEXT_PUBLIC_CHANNEL_API_KEY=your_hostaway_api_key_here
# NEXT_PUBLIC_CHANNEL_API_SECRET=your_hostaway_secret_here

# ============================================================================
# ID VERIFICATION SERVICE (Optional but Recommended)
# ============================================================================
# Choose one: veriff, persona, or signzy

# For Veriff (Recommended for simplicity)
# Sign up: https://www.veriff.com/
# Get API key from: Dashboard > Developers
NEXT_PUBLIC_ID_VERIFICATION_PROVIDER=veriff
NEXT_PUBLIC_VERIFF_API_URL=https://api.veriff.com/v1
NEXT_PUBLIC_VERIFF_API_KEY=your_veriff_api_key_here

# For Persona (Alternative - more features)
# Sign up: https://withpersona.com/
# Get API key from: Dashboard > Settings
# NEXT_PUBLIC_ID_VERIFICATION_PROVIDER=persona
# NEXT_PUBLIC_PERSONA_API_URL=https://withpersona.com/api/v1
# NEXT_PUBLIC_PERSONA_API_KEY=your_persona_api_key_here

# For Signzy (Alternative - mobile-friendly)
# Sign up: https://www.signzy.ai/
# NEXT_PUBLIC_ID_VERIFICATION_PROVIDER=signzy
# NEXT_PUBLIC_SIGNZY_API_URL=https://api.signzy.ai/v1
# NEXT_PUBLIC_SIGNZY_API_KEY=your_signzy_api_key_here

# ============================================================================
# PAYMENT PROCESSING (Optional - for future implementation)
# ============================================================================
# For Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_here

# For PayPal
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ============================================================================
# EMAIL SERVICE (Optional - for booking confirmations)
# ============================================================================
# For SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# For Mailgun
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_mailgun_domain_here

# ============================================================================
# NOTIFICATIONS (Optional)
# ============================================================================
# For WhatsApp integration
# NEXT_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_NUMBER=+1234567890

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
NEXT_PUBLIC_GA_ID=G_your_google_analytics_id
NEXT_PUBLIC_GTAG_ID=AW_your_google_ads_id

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NEXT_PUBLIC_APP_NAME=La Casa
NEXT_PUBLIC_APP_LOCATION=San Felipe del Agua, Oaxaca, Mexico
NEXT_PUBLIC_FALLBACK_EXCHANGE_RATE=20.5

# For development
NODE_ENV=development
# For production
# NODE_ENV=production

# ============================================================================
# PROPERTY INFORMATION
# ============================================================================
NEXT_PUBLIC_PROPERTY_EMAIL=bookings@lacasa.mx
NEXT_PUBLIC_PROPERTY_PHONE=+52-123-456-7890
NEXT_PUBLIC_CURRENCY_PRIMARY=USD
NEXT_PUBLIC_CURRENCY_DISPLAY=MXN

# ============================================================================
# NOTES
# ============================================================================
# - NEXT_PUBLIC_* variables are accessible in the browser
# - Other variables are server-only
# - Never commit .env.local to version control
# - Use different keys for development, staging, and production
# - Most services offer free tiers for testing
