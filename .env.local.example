# Guest Portal - Environment Configuration

# IMPORTANT: Set these values after creating a Supabase project
# 1. Create account at https://supabase.com
# 2. Create new project
# 3. Go to Settings > API to find these values

# Supabase API Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role (for server-side operations only - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Configuration
NEXT_PUBLIC_JWT_SECRET=your_jwt_secret_change_me_in_production
JWT_EXPIRY_HOURS=4

# Image Upload Configuration (Cloudinary recommended for reviews)
# Get these from https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Email Notifications (SendGrid)
# Get API key from https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@lacasaoaxaca.com

# SMS Notifications (Twilio - optional but recommended)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Cleaning Fee Configuration
NEXT_PUBLIC_CLEANING_FEE=15

# Admin Dashboard Access (basic auth for admin routes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# API Rate Limiting
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_WINDOW_MINUTES=15

# Deployment environment
NODE_ENV=development
